{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/webhook/(.*)",
      "dest": "api/webhook.js"
    },
    {
      "src": "/api/send",
      "dest": "api/webhook.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/webhook.js"
    }
  ]
}
